# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Twilio (WhatsApp Sandbox) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Facebook Messenger sender ID — format: messenger:<page-scoped-id>
# Find it in Twilio Console → Messaging → Senders → your Facebook Page
TWILIO_MESSENGER_FROM=messenger:

# ── Dashboard auth ────────────────────────────────────────────────────────────
OPERATOR_PASSWORD=changeme
JWT_SECRET=replace-with-a-long-random-string

# ── Pricing ───────────────────────────────────────────────────────────────────
TAX_RATE=0.08
DEFAULT_CURRENCY=USD

# ── Server ────────────────────────────────────────────────────────────────────
# Set to your ngrok HTTPS URL when demoing webhooks
PUBLIC_BASE_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:5173
